{
  "name": "sentrynet/gate-wp",
  "description": "The official WordPress plugin for SentryNet",
  "license": "proprietary",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.0"
  },
  "autoload": {
    "psr-4": {
      "SentryNet\\": "src"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "phpstan/extension-installer": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}
